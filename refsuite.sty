% ==============================================================================
% REFERENCE SUITE PACKAGE (refsuite)
% Centralized setup for hyperref, short references, biblatex, indexes, and
% Lua-assisted zref-clever behavior.
% ==============================================================================
\NeedsTeXFormat{LaTeX2e}[2024-06-01]
\ProvidesPackage{refsuite}[2026/06/08 alpha-0.2 reference suite]

% ==============================================================================
% DEPENDENCIES AND OPTION PROCESSING
% ==============================================================================
% refsuite currently exposes configuration through public commands rather than
% load-time options, but kvoptions keeps the package option family aligned with
% the other suite packages.

\RequirePackage{iftex}
\RequirePackage{kvoptions}

\SetupKeyvalOptions{family=refsuite,prefix=@refsuite@}

\ProcessKeyvalOptions{refsuite}

% ==============================================================================
% LUA MODULE BRIDGE
% ==============================================================================
% Map require('code.refsuite.code') to the Lua file found by kpathsea. This keeps
% Lua configuration working when examples are built from examples/.

\ifLuaTeX
  \directlua{package.preload['code.refsuite.code'] = function() return dofile(kpse.find_file('code/refsuite.code.lua')) end}
\fi

% ==============================================================================
% PACKAGE LOADING HELPER
% ==============================================================================
% The core implementation is written in expl3; this wrapper keeps package loading
% explicit and protected where feature application functions need it.

\ExplSyntaxOn
\cs_new_protected:Npn \refsuite_require_package:n #1 { \RequirePackage {#1} }
\ExplSyntaxOff

% ==============================================================================
% CORE IMPLEMENTATION
% ==============================================================================

\input{code/refsuite.core.code.tex}

\endinput
